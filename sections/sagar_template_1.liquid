<section class="custom-hero">
  <div class="hero-container">

    <!-- LEFT IMAGE -->
    <div class="hero-image">
      {% if section.settings.image != blank %}
        <img src="{{ section.settings.image | image_url: width: 1000 }}" alt="Hero Image">
      {% endif %}
    </div>

    <!-- RIGHT CONTENT -->
    <div class="hero-content">

      {% if section.settings.rating_text != blank %}
        <div class="hero-rating">
          ⭐⭐⭐⭐⭐ {{ section.settings.rating_text }}
        </div>
      {% endif %}

      {% if section.settings.heading != blank %}
        <h1>{{ section.settings.heading }}</h1>
      {% endif %}

      {% if section.settings.subtext != blank %}
        <p>{{ section.settings.subtext }}</p>
      {% endif %}

      {% if section.settings.button_label != blank %}
        <a href="{{ section.settings.button_link }}" class="hero-btn">
          {{ section.settings.button_label }}
        </a>
      {% endif %}

    </div>

  </div>
</section>

<style>
.custom-hero {
  padding: 60px 20px;
  background: #f5f5f5;
}

.hero-container {
  display: grid;
  grid-template-columns: 1fr 1fr;
  align-items: center;
  gap: 40px;
}

.hero-image img {
  width: 100%;
  border-radius: 12px;
}

.hero-content {
  max-width: 500px;
}

.hero-rating {
  font-size: 14px;
  margin-bottom: 15px;
  color: #777;
}

.hero-content h1 {
  font-size: 34px;
  margin-bottom: 15px;
  line-height: 1.3;
}

.hero-content p {
  font-size: 16px;
  color: #666;
  margin-bottom: 20px;
}

.hero-btn {
  display: inline-block;
  padding: 12px 20px;
  background: #0d2b45;
  color: #fff;
  border-radius: 8px;
  text-decoration: none;
}

.hero-btn:hover {
  background: #000;
}

@media(max-width: 768px) {
  .hero-container {
    grid-template-columns: 1fr;
  }
}
</style>

{% schema %}
{
  "name": "Custom Hero",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Left Image"
    },
    {
      "type": "text",
      "id": "rating_text",
      "label": "Rating Text",
      "default": "1,397 · Over 2 Million Sold"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "I Tried Drugstore Plumpers. They All Left My Lips Worse Than Before."
    },
    {
      "type": "textarea",
      "id": "subtext",
      "label": "Sub Text",
      "default": "Then I found the one treatment that actually worked — without the sting"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button Label",
      "default": "DISCOVER WHAT WORKED"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    }
  ],
  "presets": [
    {
      "name": "sagar_template_1",
      "category": "Custom"
    }
  ]
}
{% endschema %}